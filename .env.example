# Database
DATABASE_URL="postgresql://user:pass@ep-hostname.region.aws.neon.tech/neondb?sslmode=require"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Redis (Upstash)
REDIS_URL="redis://default:password@region-name.upstash.io:31542"
REDIS_HOST="region-name.upstash.io"
REDIS_PORT=31542
REDIS_PASSWORD="password"

# Cloudflare R2
R2_ENDPOINT="https://<id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="college-erp"
R2_PUBLIC_DOMAIN="cdn.platform.com"

# Sentry & PostHog
NEXT_PUBLIC_SENTRY_DSN="..."
NEXT_PUBLIC_POSTHOG_KEY="..."
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# API URL
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
